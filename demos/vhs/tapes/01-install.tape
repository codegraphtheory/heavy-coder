Output demos/vhs/out/01-install.mp4
Set Shell "bash"
Set FontSize 22
Set Width 1920
Set Height 1080
Set Theme "Catppuccin Mocha"
Set TypingSpeed 45ms

Type "# Heavy Coder · Hermes profile install" Enter
Sleep 800ms
Type "cat demos/vhs/assets/install-transcript.txt" Enter
Sleep 2.5s
Type "hermes -p heavy-coder chat   # Composer 2.5 coordinator" Enter
Sleep 1.5s