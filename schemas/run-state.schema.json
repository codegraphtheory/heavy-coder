{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://codegraphtheory.github.io/heavy-coder/schemas/run-state.schema.json",
  "title": "Heavy Coder Run State",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "run_id",
    "repository",
    "issue_number",
    "state",
    "history"
  ],
  "properties": {
    "run_id": {
      "type": "string",
      "minLength": 1
    },
    "repository": {
      "type": "string",
      "pattern": "^[A-Za-z0-9_.-]+/[A-Za-z0-9_.-]+$"
    },
    "issue_number": {
      "type": "integer",
      "minimum": 1
    },
    "pull_request_number": {
      "type": [
        "integer",
        "null"
      ],
      "minimum": 1
    },
    "state": {
      "enum": [
        "QUEUED",
        "CLAIMED",
        "TRIAGED",
        "CANDIDATES_RUNNING",
        "CRITIQUE",
        "SYNTHESIS",
        "LOCAL_VERIFICATION",
        "PR_OPEN",
        "CI_WAIT",
        "REPAIR",
        "AUTO_MERGE_ARMED",
        "MERGED",
        "POST_MERGE_VERIFIED",
        "BLOCKED",
        "FAILED",
        "CANCELLED"
      ]
    },
    "repair_attempts": {
      "type": "integer",
      "minimum": 0,
      "default": 0
    },
    "expected_head_sha": {
      "type": [
        "string",
        "null"
      ],
      "pattern": "^[0-9a-f]{40}$"
    },
    "history": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "state",
          "at",
          "reason"
        ],
        "properties": {
          "state": {
            "enum": [
              "QUEUED",
              "CLAIMED",
              "TRIAGED",
              "CANDIDATES_RUNNING",
              "CRITIQUE",
              "SYNTHESIS",
              "LOCAL_VERIFICATION",
              "PR_OPEN",
              "CI_WAIT",
              "REPAIR",
              "AUTO_MERGE_ARMED",
              "MERGED",
              "POST_MERGE_VERIFIED",
              "BLOCKED",
              "FAILED",
              "CANCELLED"
            ]
          },
          "at": {
            "type": "string",
            "format": "date-time"
          },
          "reason": {
            "type": "string"
          }
        }
      }
    }
  }
}
